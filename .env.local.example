# ── BlockBite — Environment Variables Template ────────────────────────────────
# Copy this file to .env.local (never commit the real .env.local)
# Set these in Vercel → Project → Settings → Environment Variables

# ── App URL (set to your actual Vercel domain after renaming the project) ──────
# Examples: https://blockbite-game.vercel.app  |  https://yourdomain.com
NEXT_PUBLIC_APP_URL=https://blockbite-game.vercel.app

# ── Solana Network ─────────────────────────────────────────────────────────────
# Options: "devnet" | "mainnet-beta"
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# ── RPC Endpoint (optional — falls back to public endpoint) ───────────────────
# Use a private RPC for production (QuickNode, Helius, Alchemy, Triton)
# NEXT_PUBLIC_RPC_URL=https://your-private-rpc.example.com

# ── Solana Program IDs ────────────────────────────────────────────────────────
# `blockbite-vesting` is deployed on devnet at the address below.
# Authority (upgrade): 35z7X59rtyts557Up1RAwpyYN7x2cFqcDc7RjPuNxFzr
NEXT_PUBLIC_VESTING_PROGRAM_ID=DvhxiL5PF8Cq3icqcjdbQvtMhJcj6LWheUgovRpaXTFf
# Game program is folded into the vesting program for the MVP (single-program
# architecture). Reuse the same ID so frontend calls land on it.
NEXT_PUBLIC_GAME_PROGRAM_ID=DvhxiL5PF8Cq3icqcjdbQvtMhJcj6LWheUgovRpaXTFf
# ── Prize Pool Stream (read by /api/prizepool) ────────────────────────────────
# After the first prize-pool create_stream succeeds, paste:
#   - the stream authority pubkey (whoever signed the create_stream)
#   - the stream_id (decimal u64 you chose for that stream)
# The API derives PDA(["vault", authority, stream_id_le], program) and reads
# the live SPL token balance. Until set, the API returns balance=0 and the UI
# shows "PRIZE POOL · 0 USDC" gracefully.
NEXT_PUBLIC_PRIZE_POOL_AUTHORITY=35z7X59rtyts557Up1RAwpyYN7x2cFqcDc7RjPuNxFzr
NEXT_PUBLIC_PRIZE_POOL_STREAM_ID=1

# ── Wallets ───────────────────────────────────────────────────────────────────
# Fee wallet collects the 0.1 SOL protocol fee on each create_schedule call.
# IMPORTANT: rotate this keypair before mainnet — the devnet one was leaked.
NEXT_PUBLIC_FEE_WALLET=TODO_REPLACE_NEW_KEYPAIR_PUBKEY
# Team wallet — collects the 15% team cut on every ticket purchase.
NEXT_PUBLIC_TEAM_WALLET=ETcQvsQek2w9feLfsqoe4AypCWfnrSwQiv3djqocaP2m

# ── USDC Mints ────────────────────────────────────────────────────────────────
# Circle official USDC on each cluster.
NEXT_PUBLIC_USDC_MINT_DEVNET=ZLkYWYvM4ZEDcPcvmcxmcgTgvsWRCXqg9ZYyQuf7njU
NEXT_PUBLIC_USDC_MINT_MAINNET=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ── Session Token Secret ───────────────────────────────────────────────────────
# HMAC-SHA256 secret for signing game session tokens.
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-random-32-byte-hex-string

# ── Vercel KV (optional — upgrade from in-memory leaderboard) ─────────────────
# Add Vercel KV storage in the dashboard, then uncomment:
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# ── Waitlist Admin Token ──────────────────────────────────────────────────────
# Token to protect /api/waitlist/list and the /waitlist/dashboard page.
# Generate with: openssl rand -hex 24
ADMIN_TOKEN=replace-with-random-token

# ── Analytics (optional) ──────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
