# ─── Node / Next.js ───────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/coverage
/.next/
/out/
/build
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
next-env.d.ts

# ─── Environment / secrets ────────────────────────────────────────────────────
.env*
.vercel
*.pem

# ─── Anchor / Rust build artifacts ───────────────────────────────────────────
# All of target/ is excluded, with explicit allow-lists below
/target/

# ALLOW: IDL and TypeScript types — needed for CI to run tests without building
!/target/idl/
!/target/types/

# Per-program build directories
programs/*/target/
# Cargo.lock IS committed for the program — it's a binary/program, not a
# library, and cargo audit cannot scan dependencies without it (Security
# Audit CI was failing with "Couldn't load Cargo.lock" before this change).

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store

# ─── Temp / logs ─────────────────────────────────────────────────────────────
anchor-build.log
*.claude-temp
*.log

# ─── Surfpool / local validator simulation artifacts ─────────────────────────
.surfpool/
test-ledger/

# ─── Scripts (may contain keypairs / secrets) ─────────────────────────────────
scripts/

# ─── Unrelated subproject dirs that must never be committed ──────────────────
blockblast/

# ─── AI agent / skills lock files ────────────────────────────────────────────
skills-lock.json
.agents/

# ─── AI dev tool session data (Claude Code internal) ─────────────────────────
# CLAUDE.md and AGENTS.md are kept (transparent AI tool disclosure).
# Only ephemeral session/permission settings are excluded.
.claude/settings.json
.claude/settings.local.json
.claude/worktrees/

# Other AI assistant session-state directories — never useful to a reviewer
.claire/
.aider*
.cursor/
.cody/
.superstack/
.windsurf/
.continue/
.zed/

# AI helper docs that are session-scratch, not part of the deliverable
build-context.md
idea-context.md
ai-scratchpad/

# OS / editor junk
Thumbs.db
desktop.ini
.idea/
*.swp
*.swo
*~

# Local Anchor wallets / keypairs — never commit any keypair, ever
*-keypair.json
*.keypair.json
wallet-*.json
