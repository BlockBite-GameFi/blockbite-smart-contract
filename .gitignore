# ─── Node / Next.js ───────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/coverage
/.next/
/out/
/build
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
next-env.d.ts

# ─── Environment / secrets ────────────────────────────────────────────────────
.env*
.vercel
*.pem

# ─── Anchor / Rust build artifacts ───────────────────────────────────────────
# All of target/ is excluded, with explicit allow-lists below
/target/

# ALLOW: IDL and TypeScript types — needed for CI to run tests without building
!/target/idl/
!/target/types/

# Per-program build directories
programs/*/target/
programs/*/Cargo.lock

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store

# ─── Temp / logs ─────────────────────────────────────────────────────────────
anchor-build.log
*.claude-temp
