# ── Solana Network ──────────────────────────────────────────────────────────────
# "devnet" (default) or "mainnet-beta"
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# RPC endpoint — override for local Surfpool testing or dedicated node
# Localnet: http://127.0.0.1:8899
# Devnet (default): https://api.devnet.solana.com
NEXT_PUBLIC_RPC_URL=

# ── Campaign Program ID ─────────────────────────────────────────────────────────
# Devnet (default):  Aso25jcqxjZ2X3A1QSV4ZgZkj4B8pw6JNd4jNVcpB7pq
# Localnet/Surfpool: 9UipodjT55vBd8zZmEPvcFc8dVCveV1CMzYW2zsDHceX
NEXT_PUBLIC_CAMPAIGN_PROGRAM_ID=

# ── Game Server ─────────────────────────────────────────────────────────────────
# URL of the running game server
# Local: http://localhost:3001
# Production: https://your-game-server.example.com
NEXT_PUBLIC_GAME_SERVER_URL=http://localhost:3001

# The PUBLIC KEY of the game server's signing keypair.
# Must match the private key configured in apps/game-server/.env → GAME_AUTHORITY_SECRET_KEY.
# Get it from the game server's GET /health response ("gameAuthority" field).
NEXT_PUBLIC_GAME_AUTHORITY_PUBKEY=

# ── USDC Mints ──────────────────────────────────────────────────────────────────
# Leave blank to use defaults
NEXT_PUBLIC_USDC_MINT_DEVNET=ZLkYWYvM4ZEDcPcvmcxmcgTgvsWRCXqg9ZYyQuf7njU
NEXT_PUBLIC_USDC_MINT_MAINNET=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
