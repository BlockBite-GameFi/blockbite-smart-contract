      "discriminator": [183, 18, 70, 156, 148, 109, 161, 34],
      "accounts": [
        { "name": "beneficiary", "signer": true },
        {
          "name": "stream",
          "writable": true,
          "pda": {
            "seeds": [
              { "kind": "const", "value": [115,116,114,101,97,109] },
